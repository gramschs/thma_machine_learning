179e\"],[0.4444444444444444,\"#bd3786\"],[0.5555555555555556,\"#d8576b\"],[0.6666666666666666,\"#ed7953\"],[0.7777777777777778,\"#fb9f3a\"],[0.8888888888888888,\"#fdca26\"],[1,\"#f0f921\"]],\"sequentialminus\":[[0,\"#0d0887\"],[0.1111111111111111,\"#46039f\"],[0.2222222222222222,\"#7201a8\"],[0.3333333333333333,\"#9c179e\"],[0.4444444444444444,\"#bd3786\"],[0.5555555555555556,\"#d8576b\"],[0.6666666666666666,\"#ed7953\"],[0.7777777777777778,\"#fb9f3a\"],[0.8888888888888888,\"#fdca26\"],[1,\"#f0f921\"]],\"diverging\":[[0,\"#8e0152\"],[0.1,\"#c51b7d\"],[0.2,\"#de77ae\"],[0.3,\"#f1b6da\"],[0.4,\"#fde0ef\"],[0.5,\"#f7f7f7\"],[0.6,\"#e6f5d0\"],[0.7,\"#b8e186\"],[0.8,\"#7fbc41\"],[0.9,\"#4d9221\"],[1,\"#276419\"]]},\"xaxis\":{\"gridcolor\":\"white\",\"linecolor\":\"white\",\"ticks\":\"\",\"title\":{\"standoff\":15},\"zerolinecolor\":\"white\",\"automargin\":true,\"zerolinewidth\":2},\"yaxis\":{\"gridcolor\":\"white\",\"linecolor\":\"white\",\"ticks\":\"\",\"title\":{\"standoff\":15},\"zerolinecolor\":\"white\",\"automargin\":true,\"zerolinewidth\":2},\"scene\":{\"xaxis\":{\"backgroundcolor\":\"#E5ECF6\",\"gridcolor\":\"white\",\"linecolor\":\"white\",\"showbackground\":true,\"ticks\":\"\",\"zerolinecolor\":\"white\",\"gridwidth\":2},\"yaxis\":{\"backgroundcolor\":\"#E5ECF6\",\"gridcolor\":\"white\",\"linecolor\":\"white\",\"showbackground\":true,\"ticks\":\"\",\"zerolinecolor\":\"white\",\"gridwidth\":2},\"zaxis\":{\"backgroundcolor\":\"#E5ECF6\",\"gridcolor\":\"white\",\"linecolor\":\"white\",\"showbackground\":true,\"ticks\":\"\",\"zerolinecolor\":\"white\",\"gridwidth\":2}},\"shapedefaults\":{\"line\":{\"color\":\"#2a3f5f\"}},\"annotationdefaults\":{\"arrowcolor\":\"#2a3f5f\",\"arrowhead\":0,\"arrowwidth\":1},\"geo\":{\"bgcolor\":\"white\",\"landcolor\":\"#E5ECF6\",\"subunitcolor\":\"white\",\"showland\":true,\"showlakes\":true,\"lakecolor\":\"white\"},\"title\":{\"x\":0.05},\"mapbox\":{\"style\":\"light\"}}},\"xaxis\":{\"anchor\":\"y\",\"domain\":[0,1],\"title\":{\"text\":\"Merkmal 1\"}},\"yaxis\":{\"anchor\":\"x\",\"domain\":[0,1],\"title\":{\"text\":\"Merkmal 2\"}},\"legend\":{\"title\":{\"text\":\"Wirkung\"},\"tracegroupgap\":0},\"title\":{\"text\":\"Künstliche Daten\"}},\"config\":{\"plotlyServerURL\":\"https://plot.ly\"}}","content_type":"application/vnd.plotly.v1+json"},"text/html":{"content_type":"text/html","hash":"4eaebfd22c787622cbc1e8ab27455171","path":"/thma_machine_learning/build/4eaebfd22c787622cbc1e8ab27455171.html"}}},"key":"OG4XQmNtfK"}],"key":"VRfYMGXxt6"}],"key":"RahZud2nF8"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":64,"column":1},"end":{"line":71,"column":1}},"children":[{"type":"text","value":"Als nächstes trainieren wir einen Entscheidungsbaum. Da Entscheidungsbäume\nhäufig zur Überanpassung (Overfitting) neigen, entscheiden wir uns, die\nBaumtiefe zu begrenzen. Aber welche Baumtiefe ist optimal? Die Baumtiefe ist ein\nHyperparameter, der vor dem Training des Modells festgelegt wird. Mithilfe der\nKreuzvalidierung können wir untersuchen, wie sich die Baumtiefe auf die\nModellqualität auswirkt. Wir testen die Baumtiefen 3, 4, 5 und 6 und geben die\nScores auf den Testdaten aus, wobei wir uns mit einer for-Schleife die Arbeit\nerleichtern.","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"c4PdXYO0Cn"}],"key":"X9fdmV7WQh"}],"key":"X4eC5qqaBe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.model_selection import cross_validate, KFold\nfrom sklearn.tree import DecisionTreeClassifier\n\n# Adaption der Daten\nX = daten[['Merkmal 1', 'Merkmal 2']]\ny = daten['Wirkung']\n\n# Vorbereitung der Kreuzvalidierung mit 10 Splits\nkfold = KFold(n_splits=10)\n\n# wiederholte Kreuzvalidierung für Baumtiefe 3, 4, 5 und 6\nfor max_tiefe in [3, 4, 5, 6]:\n    modell = DecisionTreeClassifier(max_depth=max_tiefe)\n    cv_results = cross_validate(modell, X,y, cv=kfold)\n    test_scores = cv_results['test_score']\n    print(f'Testscores: {test_scores}')","key":"iftZMBdkK0"},{"type":"outputs","id":"6whK9VCKXsrUMfeOaBnOe","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Testscores: [0.7 0.6 0.9 1.  0.8 0.5 0.9 0.6 0.8 0.7]\nTestscores: [0.7 0.6 0.6 0.8 0.8 0.5 0.7 0.6 0.8 0.7]\nTestscores: [0.7 0.7 0.8 0.9 0.8 0.6 0.7 0.7 0.8 0.7]\nTestscores: [0.7 0.5 0.7 0.9 0.9 0.6 0.7 0.5 0.8 0.7]\n"},"key":"ECxJFPpg32"}],"key":"GHiSDmxHYR"}],"key":"dtfyiJLvA1"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":92,"column":1},"end":{"line":95,"column":1}},"children":[{"type":"text","value":"Die Ausgabe von 10 Testscores ist jedoch unübersichtlich. Stattdessen berechnen\nwir besser den Mittelwert (Mean) und die Standardabweichung (Standard Deviation)\nder Scores. Dazu importieren wir ","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"TRgu5T4edi"},{"type":"inlineCode","value":"mean()","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"JQM8OWLtpP"},{"type":"text","value":" und ","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"xYaRnrvb7S"},{"type":"inlineCode","value":"std()","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"lCu3UdBXcv"},{"type":"text","value":" aus dem NumPy-Modul und\npassen die ","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"eOnCzkYYlT"},{"type":"inlineCode","value":"print()","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"xgtNwCR172"},{"type":"text","value":"-Anweisung entsprechend an.","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"fs0gZgs5r2"}],"key":"GMoWAgPP20"}],"key":"tAaLgMcVvL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from numpy import mean, std\n\nfor max_tiefe in [3, 4, 5, 6]:\n    modell = DecisionTreeClassifier(max_depth=max_tiefe)\n    cv_results = cross_validate(modell, X,y, cv=kfold)\n    test_scores = cv_results['test_score']\n    print(f'Mittelwert Testscores: {mean(test_scores):.2f}, Standardabweichung: {std(test_scores):.2f}')","key":"SLSrwatTeH"},{"type":"outputs","id":"kxqTwi4K9cdQlV2814sjr","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Mittelwert Testscores: 0.75, Standardabweichung: 0.15\nMittelwert Testscores: 0.68, Standardabweichung: 0.10\nMittelwert Testscores: 0.74, Standardabweichung: 0.08\nMittelwert Testscores: 0.71, Standardabweichung: 0.14\n"},"key":"mQlqHrA407"}],"key":"llRhALOsuJ"}],"key":"TMs0058VAx"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":107,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"Das beste Ergebnis erzielen wir mit einem Entscheidungsbaum der Tiefe 3. Diesen\nkönnten wir nun als finales Modell wählen.","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"ahiLWVLqZJ"}],"key":"IiZzkYmvMp"},{"type":"paragraph","position":{"start":{"line":110,"column":1},"end":{"line":113,"column":1}},"children":[{"type":"text","value":"Es gibt jedoch ein Problem: Wir haben die Modellauswahl mit den Scores der\nTestdaten begründet, wodurch diese in das Modelltraining eingeflossen sind. Daher\nbenötigen wir einen frischen Datensatz, um die Prognosequalität zu testen. Die\nLösung dafür ist ","position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"key":"NF4iH989RW"},{"type":"inlineCode","value":"train_test_split()","position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"key":"UsFTyYv4Cd"},{"type":"text","value":".","position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"key":"I72V44FFjm"}],"key":"VspEuhbxAg"},{"type":"paragraph","position":{"start":{"line":115,"column":1},"end":{"line":122,"column":1}},"children":[{"type":"text","value":"Zuerst teilen wir die Daten in Trainings- und Testdaten. Dann verwenden wir die\nKreuzvalidierung auf den Trainingsdaten, um die Hyperparameter zu bewerten. Die\nKreuzvalidierung teilt die Trainingsdaten erneut in Trainings- und Testdaten\nauf.  Damit diese »internen« Testdaten nicht mit den richtigen Testdaten\nverwechselt werden, nennt man sie auch ","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"RFwLLzF3IV"},{"type":"strong","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"children":[{"type":"text","value":"Validierungsdaten","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"CZWEpjLA6a"}],"key":"estQuAqSVD"},{"type":"text","value":". Die Mittelwerte\nder Scores speichern wir in einem Dictionary, um später das beste Modell zu\nermitteln. Schließlich trainieren wir das beste Modell auf allen Trainingsdaten\nund bewerten es mit den Testdaten.","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"fBpt8tfqbc"}],"key":"SrIiCi1Csa"},{"type":"paragraph","position":{"start":{"line":124,"column":1},"end":{"line":125,"column":1}},"children":[{"type":"text","value":"Das Hyperparameter-Tuning bzw. die Modellwahl mit Kreuzvalidierung funktioniert\nkomplett also wie folgt:","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"HuZTX8zdVm"}],"key":"ACl4nYXQxs"}],"key":"WgHAdN2mEI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.model_selection import cross_validate, KFold, train_test_split\nfrom sklearn.tree import DecisionTreeClassifier\n\nX = daten[['Merkmal 1', 'Merkmal 2']]\ny = daten['Wirkung']\n\nX_train, X_test, y_train, y_test = train_test_split(X,y)\n\nkfold = KFold(n_splits=10)\n\nmean_scores = {}\nfor max_tiefe in [3, 4, 5, 6]:\n    modell = DecisionTreeClassifier(max_depth=max_tiefe)\n    cv_results_modell = cross_validate(modell, X_train, y_train, cv=kfold)\n    test_scores = cv_results_modell['test_score']\n    mean_scores[max_tiefe] = mean(test_scores)\n    print(f'Mittelwert Testscores: {mean(test_scores):.2f}, Standardabweichung: {std(test_scores):.2f}')\n\n# Ermitteln der besten Baumtiefe (argmax o.ä. wäre einfacher)\ntiefe = 3\nscore = mean_scores[3]\nfor t in [4,5,6]:\n    if mean_scores[t] > score:\n        tiefe = t\n        score = mean_scores[t]\nprint(f'\\nWähle Baumtiefe {tiefe} mit dem besten Score {score:.2f}.')\n\n# Finale Modellauswahl, Training und Bewertung\nfinales_modell = DecisionTreeClassifier(max_depth=tiefe)\nfinales_modell.fit(X_train, y_train)\nfinaler_score = finales_modell.score(X_test, y_test)\nprint(f'Testscore finales Modell: {finaler_score:.2f}')","key":"UG8xqZscBC"},{"type":"outputs","id":"wBQoOeykOjsDHc4ab5vE5","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Mittelwert Testscores: 0.77, Standardabweichung: 0.14\nMittelwert Testscores: 0.73, Standardabweichung: 0.13\nMittelwert Testscores: 0.71, Standardabweichung: 0.18\nMittelwert Testscores: 0.68, Standardabweichung: 0.16\n\nWähle Baumtiefe 3 mit dem besten Score 0.77.\nTestscore finales Modell: 0.72\n"},"key":"ivpSfiQ5gr"}],"key":"uM3X74tjXh"}],"key":"rNHkkCs51q"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":162,"column":1},"end":{"line":165,"column":1}},"children":[{"type":"text","value":"Um die Hyperparameter zu optimieren und das beste Modell zu finden, haben wir\neine for-Schleife und manuelle Auswahl verwendet. Scikit-Learn bietet jedoch\neine einfachere Lösung, die wir im nächsten Abschnitt behandeln: die Gittersuche\nmit Kreuzvalidierung ","position":{"start":{"line":162,"column":1},"end":{"line":162,"column":1}},"key":"p60GBZD0wM"},{"type":"strong","position":{"start":{"line":162,"column":1},"end":{"line":162,"column":1}},"children":[{"type":"text","value":"GridSearchCV","position":{"start":{"line